# Collibra DGC base URL (no trailing slash). The REST base /rest/2.0 is appended automatically.
# Example: https://your-tenant.collibra.com
COLLIBRA_BASE_URL=https://your-tenant.collibra.com

# Basic auth credentials. The user must have permission to manage the operating model
# (Sysadmin or a role with createCommunity, createDomain, createAssetType, createAttributeType,
# createRelationType, createComplexRelationType, createStatus, createAssignment privileges).
COLLIBRA_USERNAME=your-username
COLLIBRA_PASSWORD=your-password

# Optional: dry-run mode. When set to "true", the script will log what it WOULD do
# without making any POST/PATCH/DELETE calls. GET calls still happen so verifications work.
DRY_RUN=false

# Optional: HTTP timeout in milliseconds (default 30000)
HTTP_TIMEOUT_MS=30000

# Optional: allow self-signed HTTPS certificates for on-prem/lab environments.
# WARNING: this disables TLS certificate validation for outbound HTTPS requests.
ALLOW_SELF_SIGNED_CERT=false

# Optional: log level — debug | info | warn | error
LOG_LEVEL=info
